# Application
PORT=3000
NODE_ENV=development

# Base de données MySQL (XAMPP)
# Par défaut, XAMPP expose MySQL sur le port 3306 avec l'utilisateur "root"
# sans mot de passe. Pense à créer la base "linguere" au préalable via
# phpMyAdmin (http://localhost/phpmyadmin) : CREATE DATABASE linguere;
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=
DB_NAME=linguere

# JWT
JWT_SECRET=change_this_secret_in_production
JWT_EXPIRES_IN=1d

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# API externe - OpenWeather (clé gratuite sur openweathermap.org)
OPENWEATHER_API_KEY=your_api_key_here
OPENWEATHER_CITY=Dakar

# API externe - Conversion de devises (ExchangeRate, gratuite, sans clé)
# Devise de base par défaut utilisée quand aucune n'est précisée dans la requête
EXCHANGE_RATE_BASE_CURRENCY=XOF

# OAuth2 Google (console.cloud.google.com > Credentials > OAuth Client ID)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3050/auth/google/callback

# Frontend (redirection après login Google)
FRONTEND_URL=http://localhost:5173

# Email (envoi des codes OTP à 6 chiffres)
# Avec Gmail : utiliser un "mot de passe d'application" (pas le mot de passe du compte)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=your_email@gmail.com
MAIL_PASS=your_app_password
MAIL_FROM="Linguere <no-reply@linguere.sn>"
